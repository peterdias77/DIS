@using DIS.Dashboard.Models

<RadzenCard class="dis-panel dis-panel--wide h-100">
    <RadzenStack Gap="0">
        <div class="dis-panel__header">
            <RadzenText TextStyle="TextStyle.Overline" class="dis-panel-title">OUTPUT DIAGNOSTICS</RadzenText>
        </div>

        <div class="dis-panel__body dis-panel__body--cols">

            <!-- Left Column -->
            <div class="dis-diag-col">
                <RadzenStack Gap="5px">

                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="6px" class="dis-kv-row">
                        <RadzenText TextStyle="TextStyle.Caption" class="dis-label">CONFLICT STATE</RadzenText>
                        <RadzenBadge Text="@($"{State.ConflictState} ↑")" BadgeStyle="BadgeStyle.Success" class="dis-badge-sm" />
                    </RadzenStack>

                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="6px" class="dis-kv-row">
                        <RadzenText TextStyle="TextStyle.Caption" class="dis-label">DIRECTION BIAS</RadzenText>
                        <RadzenBadge Text="@($"{State.DirectionBias} ↑")" BadgeStyle="BadgeStyle.Info" class="dis-badge-sm" />
                    </RadzenStack>

                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="6px" class="dis-kv-row">
                        <RadzenText TextStyle="TextStyle.Caption" class="dis-label">RISK ENVIRONMENT</RadzenText>
                        <RadzenBadge Text="@State.RiskEnvLeft" BadgeStyle="BadgeStyle.Warning" class="dis-badge-sm" />
                    </RadzenStack>

                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="6px" class="dis-kv-row" Style="margin-top:4px;">
                        <RadzenText TextStyle="TextStyle.Caption" class="dis-label">RE-RANK</RadzenText>
                        <div class="dis-rerank__next">NEXT RANK @State.ReRankCountdown</div>
                    </RadzenStack>

                    <div class="dis-rank-strip">
                        @foreach (var r in State.RankStrip)
                        {
                            <div class="dis-rank-strip__slot @(r.Active ? "dis-rank-strip__slot--active" : "")">
                                <span class="dis-rank-strip__num">@r.Number</span>
                                <span class="dis-rank-strip__sub">@r.Sub</span>
                            </div>
                        }
                    </div>

                </RadzenStack>
            </div>

            <!-- Right Column -->
            <div class="dis-diag-col">
                <RadzenStack Gap="5px">

                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="6px" class="dis-kv-row">
                        <RadzenText TextStyle="TextStyle.Caption" class="dis-label">RISK ENVIRONMENT</RadzenText>
                        <RadzenBadge Text="@State.RiskEnvRight" BadgeStyle="BadgeStyle.Warning" class="dis-badge-sm" />
                    </RadzenStack>

                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="6px" class="dis-kv-row">
                        <RadzenText TextStyle="TextStyle.Caption" class="dis-label">EXECUTION QUALITY</RadzenText>
                        <RadzenBadge Text="@State.ExecutionQuality" BadgeStyle="BadgeStyle.Success" class="dis-badge-sm" />
                        <RadzenText TextStyle="TextStyle.Caption" Style="color:var(--rz-text-disabled-color);">@State.ExecutionQualityNum</RadzenText>
                    </RadzenStack>

                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="6px" class="dis-kv-row">
                        <RadzenText TextStyle="TextStyle.Caption" class="dis-label">BEHAVIOR TYPE</RadzenText>
                        <RadzenText TextStyle="TextStyle.Body2" Style="color:var(--rz-text-color);">@State.BehaviorType</RadzenText>
                    </RadzenStack>

                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="6px" class="dis-kv-row">
                        <RadzenText TextStyle="TextStyle.Caption" class="dis-label">CROWD CONDITION</RadzenText>
                        <RadzenText TextStyle="TextStyle.Body2" Style="color:var(--rz-text-color);">@State.CrowdCondition</RadzenText>
                    </RadzenStack>

                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="6px" class="dis-kv-row">
                        <RadzenText TextStyle="TextStyle.Caption" class="dis-label">TF ALIGNMENT</RadzenText>
                        <RadzenBadge Text="@State.TfAlignment" BadgeStyle="BadgeStyle.Info" class="dis-badge-sm" />
                    </RadzenStack>

                </RadzenStack>
            </div>

        </div>
    </RadzenStack>
</RadzenCard>

@code {
    [Parameter, EditorRequired] public DashboardState State { get; set; } = default!;
}

@using DIS.Dashboard.Models

<RadzenCard class="dis-panel h-100">
    <RadzenStack Gap="0">
        <div class="dis-panel__header">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="8px">
                <RadzenText TextStyle="TextStyle.Overline" class="dis-panel-title">ENTRY &amp; EXIT SIGNALS</RadzenText>
                <RadzenIcon Icon="edit" Style="color:var(--rz-primary); font-size:13px; cursor:pointer;" />
            </RadzenStack>
        </div>

        <div class="dis-panel__body dis-panel__body--signals">

            <!-- State Signals Column -->
            <div class="dis-signals-col">
                <div class="dis-signals-col__header">
                    <RadzenText TextStyle="TextStyle.Caption" Style="color:var(--rz-text-disabled-color); font-weight:700; letter-spacing:1px; text-transform:uppercase;">
                        STATE SIGNALS
                    </RadzenText>
                    <RadzenIcon Icon="trending_up" Style="color:var(--rz-primary); font-size:13px;" />
                </div>

                @foreach (var sig in State.StateSignals)
                {
                    <div class="dis-signal-row">
                        <RadzenText TextStyle="TextStyle.Body2" Style="color:var(--rz-primary); font-weight:700; min-width:50px;">@sig.Asset</RadzenText>
                        <div class="dis-signal__chart" style="flex:1;">
                            <RadzenText TextStyle="TextStyle.Caption" Style="color:var(--rz-text-disabled-color); overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@sig.ChartLine1</RadzenText>
                            <RadzenText TextStyle="TextStyle.Caption" Style="color:var(--rz-text-disabled-color); overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@sig.ChartLine2</RadzenText>
                        </div>
                    </div>
                }

                <div class="dis-signals-col__footer">
                    <RadzenText TextStyle="TextStyle.Caption" Style="color:var(--rz-text-disabled-color);">RISK LEVEL</RadzenText>
                    <div class="dis-risk-badges">
                        @foreach (var b in State.RiskBadges)
                        {
                            <RadzenBadge Text="@b" BadgeStyle="BadgeStyle.Secondary" class="dis-badge-xs" />
                        }
                    </div>
                </div>
            </div>

            <!-- Entry Signals Column -->
            <div class="dis-signals-col">
                <div class="dis-signals-col__header">
                    <RadzenText TextStyle="TextStyle.Caption" Style="color:var(--rz-text-disabled-color); font-weight:700; letter-spacing:1px; text-transform:uppercase;">
                        ENTRY SIGNALS
                    </RadzenText>
                </div>

                @foreach (var sig in State.EntrySignals)
                {
                    <div class="dis-signal-row">
                        <RadzenText TextStyle="TextStyle.Body2" Style="color:var(--rz-primary); font-weight:700; min-width:50px;">@sig.Asset</RadzenText>
                        <div class="dis-signal__chart" style="flex:1;">
                            <RadzenText TextStyle="TextStyle.Caption" Style="color:var(--rz-text-disabled-color); overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@sig.ChartLine1</RadzenText>
                            <RadzenText TextStyle="TextStyle.Caption" Style="color:var(--rz-text-disabled-color); overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@sig.ChartLine2</RadzenText>
                        </div>
                        <RadzenBadge Text="↓" BadgeStyle="BadgeStyle.Secondary" class="dis-badge-xs" />
                    </div>
                }

                <div class="dis-signals-col__footer">
                    <RadzenText TextStyle="TextStyle.Caption" Style="color:var(--rz-text-disabled-color);">RISK</RadzenText>
                    <div class="dis-risk-badges">
                        <RadzenBadge Text="@State.EntryRisk" BadgeStyle="BadgeStyle.Secondary" class="dis-badge-xs" />
                    </div>
                </div>
            </div>

        </div>
    </RadzenStack>
</RadzenCard>

@code {
    [Parameter, EditorRequired] public DashboardState State { get; set; } = default!;
}

@using DIS.Dashboard.Models

<RadzenCard class="dis-panel h-100">
    <RadzenStack Gap="0">
        <div class="dis-panel__header">
            <RadzenText TextStyle="TextStyle.Overline" class="dis-panel-title">CURRENT SYSTEM STATE</RadzenText>
        </div>

        <RadzenStack Gap="6px" class="dis-panel__body">

            <!-- STRUCTURE -->
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="6px" class="dis-kv-row">
                <RadzenText TextStyle="TextStyle.Caption" class="dis-label">STRUCTURE</RadzenText>
                <RadzenBadge Text="@State.StructureCondition" BadgeStyle="BadgeStyle.Success" class="dis-badge-sm" />
                <RadzenBadge Text="@($"TREND {State.CycleId} ↑")" BadgeStyle="BadgeStyle.Info" class="dis-badge-sm" />
            </RadzenStack>

            <!-- REGIME -->
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="6px" class="dis-kv-row">
                <RadzenText TextStyle="TextStyle.Caption" class="dis-label">REGIME</RadzenText>
                <RadzenText TextStyle="TextStyle.Subtitle2" Style="color:var(--rz-primary); font-weight:700; letter-spacing:1px;">@State.Regime</RadzenText>
                <div class="dis-sparkline dis-sparkline--green rz-ml-auto">
                    @foreach (var v in State.RegimeSparkline)
                    {
                        <div class="dis-sparkline__bar" style="height:@(v)%"></div>
                    }
                </div>
            </RadzenStack>

            <!-- VOLATILITY -->
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="6px" class="dis-kv-row">
                <RadzenText TextStyle="TextStyle.Caption" class="dis-label">VOLATILITY</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2" Style="color:var(--rz-text-color);">@State.Volatility</RadzenText>
                <div class="dis-sparkline dis-sparkline--dim rz-ml-auto">
                    @foreach (var v in State.VolSparkline)
                    {
                        <div class="dis-sparkline__bar" style="height:@(v)%"></div>
                    }
                </div>
            </RadzenStack>

            <!-- STRENGTH -->
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="6px" class="dis-kv-row">
                <RadzenText TextStyle="TextStyle.Caption" class="dis-label">STRENGTH</RadzenText>
                <RadzenText TextStyle="TextStyle.Subtitle2" Style="color:#fff; font-size:12px; font-weight:700; letter-spacing:1px;">@State.Strength</RadzenText>
                <div class="dis-sparkline dis-sparkline--dim rz-ml-auto">
                    @foreach (var v in State.StrengthSparkline)
                    {
                        <div class="dis-sparkline__bar" style="height:@(v)%"></div>
                    }
                </div>
            </RadzenStack>

            <RadzenDivider Style="margin:4px 0; border-color:var(--rz-border-disabled-color);" />

            <!-- LAST LOG -->
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="6px" class="dis-kv-row">
                <RadzenText TextStyle="TextStyle.Caption" class="dis-label">LAST LOG</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2" Style="color:var(--rz-text-color);">@State.LastLogTime</RadzenText>
                <div class="dis-barset rz-ml-auto">
                    @for (int i = 0; i < 8; i++)
                    {
                        <div class="dis-barset__bar @(i < State.LogBarsFilled ? "dis-barset__bar--lit" : "")"></div>
                    }
                </div>
            </RadzenStack>

        </RadzenStack>
    </RadzenStack>
</RadzenCard>

@code {
    [Parameter, EditorRequired] public DashboardState State { get; set; } = default!;
}

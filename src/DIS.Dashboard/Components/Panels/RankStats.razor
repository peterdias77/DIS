@using DIS.Dashboard.Models

<div class="dis-panel">
    <div class="dis-panel__header">RANK DIAGNOSTICS</div>
    <div class="dis-panel__body">

        <div class="dis-stat-row">
            <span class="dis-stat__label">TOTAL LOGS:</span>
            <span class="dis-stat__value">@State.TotalLogs</span>
        </div>
        <div class="dis-stat-row">
            <span class="dis-stat__label">STATE CHANGES:</span>
            <span class="dis-stat__value">@State.StateChanges</span>
        </div>
        <div class="dis-stat-row">
            <span class="dis-stat__label">OUTPUT CHANGES:</span>
            <span class="dis-stat__value">@State.OutputChanges</span>
        </div>
        <div class="dis-stat-row">
            <span class="dis-stat__label">DECISION LOGS:</span>
            <span class="dis-stat__value">@State.DecisionLogs</span>
        </div>
        <div class="dis-stat-row">
            <span class="dis-stat__label">ACTION EVENTS:</span>
            <span class="dis-stat__value">@State.ActionEvents</span>
        </div>

    </div>
</div>

@code {
    [Parameter, EditorRequired] public DashboardState State { get; set; } = default!;
}

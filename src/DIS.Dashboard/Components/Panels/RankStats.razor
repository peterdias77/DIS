@using DIS.Dashboard.Models

<RadzenCard class="dis-panel h-100" Style="background:var(--bg-panel);border:1px solid var(--border);border-radius:4px;box-shadow:none;padding:0;" Variant="Variant.Outlined">
    <RadzenStack Gap="0">
        <div class="dis-panel__header">
            <RadzenText TextStyle="TextStyle.Overline" class="dis-panel-title">RANK DIAGNOSTICS</RadzenText>
        </div>

        <RadzenStack Gap="0" class="dis-panel__body">

            @foreach (var (label, value) in new (string, int)[]
            {
                ("TOTAL LOGS",     State.TotalLogs),
                ("STATE CHANGES",  State.StateChanges),
                ("OUTPUT CHANGES", State.OutputChanges),
                ("DECISION LOGS",  State.DecisionLogs),
                ("ACTION EVENTS",  State.ActionEvents),
            })
            {
                <div class="dis-stat-row">
                    <RadzenText TextStyle="TextStyle.Caption" Style="color:var(--rz-text-disabled-color);">@label</RadzenText>
                    <RadzenText TextStyle="TextStyle.H6" Style="color:var(--rz-text-color); font-weight:700; font-size:12px;">@value</RadzenText>
                </div>
            }

        </RadzenStack>
    </RadzenStack>
</RadzenCard>

@code {
    [Parameter, EditorRequired] public DashboardState State { get; set; } = default!;
}

@using DIS.Dashboard.Models

<RadzenCard class="dis-panel h-100" Style="background:var(--bg-panel);border:1px solid var(--border);border-radius:4px;box-shadow:none;padding:0;" Variant="Variant.Outlined">
    <RadzenStack Gap="0">
        <div class="dis-panel__header">
            <RadzenText TextStyle="TextStyle.Overline" class="dis-panel-title">LOGGING SUMMARY</RadzenText>
        </div>

        <RadzenStack Gap="5px" class="dis-panel__body">

            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="6px" class="dis-kv-row">
                <RadzenText TextStyle="TextStyle.Caption" class="dis-label">POSITION SIZE</RadzenText>
                <RadzenBadge Text="@($"{State.PositionSizeLabel} ↑")" BadgeStyle="BadgeStyle.Info" class="dis-badge-sm" />
            </RadzenStack>

            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="6px" class="dis-kv-row">
                <RadzenText TextStyle="TextStyle.Caption" class="dis-label">ENTERED SIZE</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2" Style="color:var(--rz-text-color);">@State.EnteredSize LOTS</RadzenText>
            </RadzenStack>

            <RadzenDivider Style="margin:2px 0; border-color:var(--rz-border-disabled-color);" />

            <div class="dis-stat-row">
                <RadzenText TextStyle="TextStyle.Caption" Style="color:var(--rz-text-disabled-color);">TOTAL LOGS</RadzenText>
                <RadzenText TextStyle="TextStyle.Body1" Style="color:var(--rz-text-color); font-weight:700;">@State.TotalLogs</RadzenText>
            </div>

            <div class="dis-stat-row">
                <RadzenText TextStyle="TextStyle.Caption" Style="color:var(--rz-text-disabled-color);">ACTIVE CYCLE</RadzenText>
                <RadzenBadge Text="@State.ActiveCycleLabel" BadgeStyle="BadgeStyle.Warning" class="dis-badge-sm" />
            </div>

            <div class="dis-stat-row">
                <RadzenText TextStyle="TextStyle.Caption" Style="color:var(--rz-text-disabled-color);">LAST LOGGED</RadzenText>
                <RadzenBadge Text="@State.LastLogged" BadgeStyle="BadgeStyle.Warning" class="dis-badge-sm" />
            </div>

            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="6px" class="dis-kv-row">
                <RadzenText TextStyle="TextStyle.Caption" class="dis-label">STOP LOSS</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2" Style="color:var(--rz-text-color);">@State.StopLossDisplay</RadzenText>
                <RadzenBadge Text="↑" BadgeStyle="BadgeStyle.Success" class="dis-badge-xs" />
            </RadzenStack>

            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="6px" class="dis-kv-row">
                <RadzenText TextStyle="TextStyle.Caption" class="dis-label">LAST ERROR</RadzenText>
                <RadzenBadge Text="@State.LastError" BadgeStyle="BadgeStyle.Secondary" class="dis-badge-sm" />
            </RadzenStack>

        </RadzenStack>
    </RadzenStack>
</RadzenCard>

@code {
    [Parameter, EditorRequired] public DashboardState State { get; set; } = default!;
}

@using DIS.Dashboard.Models

<RadzenCard class="dis-panel h-100" Style="background:var(--bg-panel);border:1px solid var(--border);border-radius:4px;box-shadow:none;padding:0;" Variant="Variant.Outlined">
    <RadzenStack Gap="0">
        <div class="dis-panel__header">
            <RadzenText TextStyle="TextStyle.Overline" class="dis-panel-title">LOGGING SUMMARY</RadzenText>
        </div>

        <RadzenStack Gap="0" class="dis-panel__body" Style="overflow:hidden; flex:1;">
            @foreach (var entry in State.LogEntries)
            {
                <div class="dis-log-entry">
                    <RadzenText TextStyle="TextStyle.Caption" class="dis-log__time">@entry.Time</RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption" class=@($"dis-log__type {@GetTypeClass(entry.Type)}")>@entry.Type</RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption" class="dis-log__detail">@entry.Detail</RadzenText>
                </div>
            }
        </RadzenStack>

    </RadzenStack>
</RadzenCard>

@code {
    [Parameter, EditorRequired] public DashboardState State { get; set; } = default!;

    private static string GetTypeClass(string type) => type switch
    {
        "STATE CHANGE:"  => "dis-log__type--state",
        "OUTPUT CHANGE:" => "dis-log__type--output",
        "ENTRY SIGNAL"   => "dis-log__type--entry",
        "EXECUTION"      => "dis-log__type--exec",
        "EXIT"           => "dis-log__type--exit",
        _                => ""
    };
}

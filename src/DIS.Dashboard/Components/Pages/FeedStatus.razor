@page "/feed"
@using DIS.Core.Models
@using DIS.Dashboard.Services
@inject DashboardHubClient HubClient
@inject ILogReader LogReader
@implements IDisposable

<h1>Feed Status</h1>

<div class="dis-feed-summary">
    <div class="dis-card">
        <label>EA Connection</label>
        <span class="@(_snapshot?.EaConnected == true ? "dis-val--green" : "dis-val--red")">
            @(_snapshot?.EaConnected == true ? "CONNECTED" : "DISCONNECTED")
        </span>
    </div>
    <div class="dis-card">
        <label>Symbols OK</label>
        <span>@(_snapshot?.SymbolsOk ?? 0) / @(_snapshot?.SymbolsTotal ?? 20)</span>
    </div>
    <div class="dis-card">
        <label>Stale</label>
        <span class="@(_snapshot?.SymbolsStale > 0 ? "dis-val--yellow" : "")">
            @(_snapshot?.SymbolsStale ?? 0)
        </span>
    </div>
    <div class="dis-card">
        <label>No Data</label>
        <span class="@(_snapshot?.SymbolsNoData > 0 ? "dis-val--red" : "")">
            @(_snapshot?.SymbolsNoData ?? 0)
        </span>
    </div>
    <div class="dis-card">
        <label>Total Bars Stored</label>
        <span>@(_snapshot?.TotalBarsStored.ToString("N0") ?? "—")</span>
    </div>
    <div class="dis-card">
        <label>Last Update</label>
        <span>@(_snapshot?.Timestamp.ToString("HH:mm:ss") ?? "—")</span>
    </div>
</div>

@if (_snapshot is null)
{
    <p class="dis-empty">Waiting for feed health data from DIS Engine...</p>
    <p class="dis-empty" style="font-size:11px; margin-top:4px;">
        Make sure DIS.Engine is running and the MT5 EA (DIS.mq5) is connected.
    </p>
}
else
{
    <table class="dis-table" style="margin-top: 16px;">
        <thead>
            <tr>
                <th>#</th>
                <th>Symbol</th>
                <th>Status</th>
                <th>History</th>
                <th>Bars Stored</th>
                <th>Session Bars</th>
                <th>Last Bar (UTC)</th>
                <th>Age</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var (sym, idx) in _snapshot.Symbols.Select((s, i) => (s, i + 1)))
            {
                <tr class="@GetRowClass(sym.Status)">
                    <td>@idx</td>
                    <td><strong>@sym.Symbol</strong></td>
                    <td>
                        <span class="dis-badge @GetStatusBadgeClass(sym.Status)">
                            @sym.Status
                        </span>
                    </td>
                    <td>
                        <span class="dis-badge @(sym.HistoryLoaded ? "dis-badge--green" : "dis-badge--dim")">
                            @(sym.HistoryLoaded ? "LOADED" : "PENDING")
                        </span>
                    </td>
                    <td>@sym.BarCount.ToString("N0")</td>
                    <td>@sym.BarsThisSession</td>
                    <td>@(sym.LastBarTime.HasValue ? sym.LastBarTime.Value.ToString("HH:mm:ss") : "—")</td>
                    <td class="@GetAgeClass(sym.LastBarTime)">@FormatAge(sym.LastBarTime)</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private FeedHealthSnapshot? _snapshot;

    protected override void OnInitialized()
    {
        HubClient.OnFeedHealth += OnFeedHealthReceived;
    }

    private void OnFeedHealthReceived(FeedHealthSnapshot snapshot)
    {
        InvokeAsync(() =>
        {
            _snapshot = snapshot;
            StateHasChanged();
        });
    }

    private static string GetRowClass(string status) => status switch
    {
        "STALE"        => "warning",
        "NO_DATA"      => "error",
        "DISCONNECTED" => "error",
        _              => ""
    };

    private static string GetStatusBadgeClass(string status) => status switch
    {
        "OK"           => "dis-badge--green",
        "STALE"        => "dis-badge--yellow",
        "NO_DATA"      => "dis-badge--red",
        "DISCONNECTED" => "dis-badge--red",
        _              => "dis-badge--dim"
    };

    private static string GetAgeClass(DateTime? lastBar)
    {
        if (lastBar is null) return "";
        var age = DateTime.UtcNow - lastBar.Value;
        return age > TimeSpan.FromMinutes(3) ? "warning" : "";
    }

    private static string FormatAge(DateTime? lastBar)
    {
        if (lastBar is null) return "—";
        var age = DateTime.UtcNow - lastBar.Value;
        if (age.TotalSeconds < 60)  return $"{(int)age.TotalSeconds}s ago";
        if (age.TotalMinutes < 60)  return $"{(int)age.TotalMinutes}m ago";
        return $"{(int)age.TotalHours}h ago";
    }

    public void Dispose() => HubClient.OnFeedHealth -= OnFeedHealthReceived;
}

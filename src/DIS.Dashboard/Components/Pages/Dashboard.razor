@page "/"
@using DIS.Dashboard.Models
@implements IDisposable
@inject IDashboardStateService StateService

<PageTitle>DIS — Decision Intelligence System</PageTitle>

<div class="dis-dashboard">

    <!-- ═══════════════════════════════════════════════════════════
         HEADER
    ═══════════════════════════════════════════════════════════ -->
    <header class="dis-header">
        <div class="dis-header__title">
            <span class="dis-header__brand">DECISION INTELLIGENCE SYSTEM</span>
            <span class="dis-header__label">DASHBOARD</span>
        </div>
        <div class="dis-header__clock">
            <span class="dis-header__time">@_now.ToString("HH:mm:ss")</span>
            <span class="dis-header__date">@_now.ToString("yyyy-MM-dd")</span>
        </div>
    </header>

    <!-- ═══════════════════════════════════════════════════════════
         ROW 1 — CURRENT STATE / OUTPUT DIAGNOSTICS / PORTFOLIO
    ═══════════════════════════════════════════════════════════ -->
    <div class="dis-grid dis-grid--top">

        <!-- PANEL: Current System State -->
        <div class="dis-panel">
            <div class="dis-panel__header">CURRENT SYSTEM STATE</div>
            <div class="dis-panel__body">
                <div class="dis-kv-row">
                    <span class="dis-kv__label">STRUCTURE:</span>
                    <span class="dis-badge dis-badge--green">@State.StructureCondition</span>
                    <span class="dis-badge dis-badge--cyan dis-badge--arrow-up">TREND @State.CycleId</span>
                </div>
                <div class="dis-kv-row">
                    <span class="dis-kv__label">REGIME:</span>
                    <span class="dis-regime-value">@State.Regime</span>
                    <div class="dis-sparkline dis-sparkline--green">
                        @foreach (var v in State.RegimeSparkline)
                        {
                            <div class="dis-sparkline__bar" style="height: @(v)%"></div>
                        }
                    </div>
                </div>
                <div class="dis-kv-row">
                    <span class="dis-kv__label">VOLATILITY:</span>
                    <span class="dis-kv__value dis-kv__value--normal">@State.Volatility</span>
                    <div class="dis-sparkline dis-sparkline--dim">
                        @foreach (var v in State.VolSparkline)
                        {
                            <div class="dis-sparkline__bar" style="height: @(v)%"></div>
                        }
                    </div>
                </div>
                <div class="dis-kv-row">
                    <span class="dis-kv__label">STRENGTH:</span>
                    <span class="dis-kv__value dis-kv__value--strong">@State.Strength</span>
                    <div class="dis-sparkline dis-sparkline--dim">
                        @foreach (var v in State.StrengthSparkline)
                        {
                            <div class="dis-sparkline__bar" style="height: @(v)%"></div>
                        }
                    </div>
                </div>
                <div class="dis-kv-row dis-kv-row--footer">
                    <span class="dis-kv__label">LAST LOG:</span>
                    <span class="dis-kv__value">@State.LastLogTime</span>
                    <div class="dis-barset">
                        @for (int i = 0; i < 8; i++)
                        {
                            <div class="dis-barset__bar @(i < State.LogBarsFilled ? "dis-barset__bar--lit" : "")"></div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- PANEL: Output Diagnostics (split left/right) -->
        <div class="dis-panel dis-panel--wide">
            <div class="dis-panel__header">OUTPUT DIAGNOSTICS</div>
            <div class="dis-panel__body dis-panel__body--cols">
                <div class="dis-diag-col">
                    <div class="dis-kv-row">
                        <span class="dis-kv__label">CONFLICT STATE:</span>
                        <span class="dis-badge dis-badge--green dis-badge--arrow-up">@State.ConflictState</span>
                    </div>
                    <div class="dis-kv-row">
                        <span class="dis-kv__label">DIRECTION BIAS:</span>
                        <span class="dis-badge dis-badge--cyan dis-badge--arrow-up">@State.DirectionBias</span>
                    </div>
                    <div class="dis-kv-row">
                        <span class="dis-kv__label">RISK ENVIRONMENT:</span>
                        <span class="dis-badge dis-badge--yellow">@State.RiskEnvLeft</span>
                    </div>
                    <div class="dis-kv-row dis-kv-row--rerank">
                        <span class="dis-kv__label">RE-RANK:</span>
                        <div class="dis-rerank">
                            <span class="dis-rerank__next">NEXT RANK @State.ReRankCountdown</span>
                        </div>
                    </div>
                    <div class="dis-rank-strip">
                        @foreach (var r in State.RankStrip)
                        {
                            <div class="dis-rank-strip__slot @(r.Active ? "dis-rank-strip__slot--active" : "")">
                                <span class="dis-rank-strip__num">@r.Number</span>
                                <span class="dis-rank-strip__sub">@r.Sub</span>
                            </div>
                        }
                    </div>
                </div>
                <div class="dis-diag-col">
                    <div class="dis-kv-row">
                        <span class="dis-kv__label">RISK ENVIRONMENT:</span>
                        <span class="dis-badge dis-badge--yellow">@State.RiskEnvRight</span>
                    </div>
                    <div class="dis-kv-row">
                        <span class="dis-kv__label">EXECUTION QUALITY:</span>
                        <span class="dis-badge dis-badge--green">@State.ExecutionQuality</span>
                        <span class="dis-kv__value dis-kv__muted">@State.ExecutionQualityNum</span>
                    </div>
                    <div class="dis-kv-row">
                        <span class="dis-kv__label">BEHAVIOR TYPE:</span>
                        <span class="dis-kv__value">@State.BehaviorType</span>
                    </div>
                    <div class="dis-kv-row">
                        <span class="dis-kv__label">CROWD CONDITION:</span>
                        <span class="dis-kv__value">@State.CrowdCondition</span>
                    </div>
                    <div class="dis-kv-row">
                        <span class="dis-kv__label">TIMEFRAME ALIGNMENT:</span>
                        <span class="dis-badge dis-badge--cyan">@State.TfAlignment</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- PANEL: Portfolio Overview -->
        <div class="dis-panel">
            <div class="dis-panel__header">PORTFOLIO OVERVIEW</div>
            <div class="dis-panel__body">
                <div class="dis-kv-row dis-kv-row--cycle">
                    <span class="dis-kv__label">CYCLE:</span>
                    <span class="dis-kv__value">RANK <strong>@State.CycleRank</strong> OF <strong>@State.CycleMax</strong></span>
                    <span class="dis-badge dis-badge--cyan dis-badge--sm">@State.CycleAsset</span>
                </div>
                <div class="dis-kv-row">
                    <span class="dis-kv__label">ASSETS IN CYCLE:</span>
                    <span class="dis-kv__value">@State.AssetsInCycle</span>
                </div>
                <div class="dis-kv-row">
                    <span class="dis-kv__label">TRADING PERMISSION:</span>
                    <span class="dis-badge @(State.TradingPermission == "ALLOW" ? "dis-badge--green" : "dis-badge--red")">@State.TradingPermission</span>
                </div>
                <div class="dis-kv-row dis-kv-row--pnl">
                    <span class="dis-kv__label">OPEN P/L:</span>
                    <span class="dis-pnl @(State.OpenPnl >= 0 ? "dis-pnl--pos" : "dis-pnl--neg")">
                        @(State.OpenPnl >= 0 ? "+" : "")$@State.OpenPnl.ToString("N2")
                    </span>
                </div>
                <div class="dis-kv-row dis-kv-row--pnl">
                    <span class="dis-kv__label">TOTAL P/L:</span>
                    <span class="dis-pnl dis-pnl--lg @(State.TotalPnl >= 0 ? "dis-pnl--pos" : "dis-pnl--neg")">
                        @(State.TotalPnl >= 0 ? "+" : "")$@State.TotalPnl.ToString("N2")
                    </span>
                </div>
                <div class="dis-kv-row">
                    <span class="dis-kv__label">SYSTEM STATE:</span>
                    <span class="dis-badge dis-badge--cyan dis-badge--arrow-down">@State.SystemState</span>
                </div>
            </div>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════
         ROW 2 — ACTIVE TRADES / RANK DIAGNOSTICS / LOGGING
    ═══════════════════════════════════════════════════════════ -->
    <div class="dis-grid dis-grid--mid">

        <!-- PANEL: Active Trades -->
        <div class="dis-panel dis-panel--trades">
            <div class="dis-panel__header">ACTIVE TRADES</div>
            <div class="dis-trades-table">
                <div class="dis-trades-table__head">
                    <span>ASSET</span>
                    <span>DIRECTION</span>
                    <span>POSITION</span>
                    <span>ENTRY</span>
                    <span>P/NL</span>
                    <span>STOP LOSS</span>
                </div>
                @foreach (var (trade, idx) in State.ActiveTrades.Select((t, i) => (t, i + 1)))
                {
                    <div class="dis-trades-table__row">
                        <span class="dis-trade__asset">@idx. @trade.Asset</span>
                        <span class="dis-badge @(trade.Direction == "LONG" ? "dis-badge--green" : "dis-badge--red") dis-badge--dir">
                            @trade.Direction
                            <span class="dis-badge__arrow">@(trade.Direction == "LONG" ? "▲" : "▼")</span>
                        </span>
                        <span class="dis-trade__pos">@trade.Position</span>
                        <span class="dis-trade__entry">@trade.EntryPrice.ToString("N2")</span>
                        <span class="dis-trade__pnl @(trade.Pnl >= 0 ? "dis-pnl--pos" : "dis-pnl--neg")">
                            @(trade.Pnl >= 0 ? "+" : "")$@trade.Pnl.ToString("N2")
                        </span>
                        <span class="dis-trade__sl">@trade.StopLoss.ToString("N2")</span>
                    </div>
                }
            </div>
        </div>

        <!-- PANEL: Rank Diagnostics -->
        <div class="dis-panel">
            <div class="dis-panel__header">RANK DIAGNOSTICS</div>
            <div class="dis-panel__body dis-panel__body--rank">
                <div class="dis-rank-grid">
                    @foreach (var slot in State.RankSlots)
                    {
                        <div class="dis-rank-box @(slot.Occupied ? "dis-rank-box--occupied" : "") @(slot.Highlighted ? "dis-rank-box--highlighted" : "")">
                            <span class="dis-rank-box__num">@slot.Rank</span>
                        </div>
                    }
                </div>
                <div class="dis-rank-grid dis-rank-grid--sub">
                    @foreach (var slot in State.RankSlots)
                    {
                        <div class="dis-rank-sub">@slot.Rank</div>
                    }
                </div>
                <!-- Cycle Status Donut -->
                <div class="dis-cycle-status">
                    <svg class="dis-donut" viewBox="0 0 80 80">
                        <circle cx="40" cy="40" r="32" fill="none" stroke="#1e2a3a" stroke-width="8"/>
                        <circle cx="40" cy="40" r="32" fill="none" stroke="#00c8ff" stroke-width="8"
                                stroke-dasharray="@State.DonutFill @State.DonutGap"
                                stroke-dashoffset="25" stroke-linecap="round"/>
                        <text x="40" y="38" text-anchor="middle" class="dis-donut__big">@State.CycleId</text>
                        <text x="40" y="52" text-anchor="middle" class="dis-donut__small">CYCLE</text>
                    </svg>
                    <div class="dis-cycle-status__legend">
                        <div class="dis-cycle-legend-grid">
                            @foreach (int n in new[] { 1, 2, 3, 4 })
                            {
                                <span class="dis-cycle-legend__item @(n <= State.AssetsInCycle ? "dis-cycle-legend__item--active" : "")">@n</span>
                            }
                        </div>
                        <div class="dis-cycle-status__label">CYCLE STATUS</div>
                        <div class="dis-cycle-id-row">
                            @foreach (int n in new[] { 1, 2, 3, 4 })
                            {
                                <span class="dis-cycle-id__item">@n</span>
                            }
                        </div>
                        <div class="dis-cycle-id-label">CYCLE ID: @State.CycleId</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- PANEL: Logging Summary -->
        <div class="dis-panel">
            <div class="dis-panel__header">LOGGING SUMMARY</div>
            <div class="dis-panel__body">
                @foreach (var entry in State.LogEntries)
                {
                    <div class="dis-log-entry">
                        <span class="dis-log__time">@entry.Time</span>
                        <span class="dis-log__type @GetLogTypeClass(entry.Type)">@entry.Type</span>
                        <span class="dis-log__detail">@entry.Detail</span>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════
         ROW 3 — ENTRY/EXIT SIGNALS / RANK STATS / LOGGING SUMMARY
    ═══════════════════════════════════════════════════════════ -->
    <div class="dis-grid dis-grid--bot">

        <!-- PANEL: Entry & Exit Signals -->
        <div class="dis-panel">
            <div class="dis-panel__header">ENTRY &amp; EXIT SIGNALS <span class="dis-header__pencil">✎</span></div>
            <div class="dis-panel__body dis-panel__body--signals">
                <div class="dis-signals-col">
                    <div class="dis-signals-col__header">STATE SIGNALS <span class="dis-arrow-icon">↗</span></div>
                    @foreach (var sig in State.StateSignals)
                    {
                        <div class="dis-signal-row">
                            <span class="dis-signal__asset">@sig.Asset</span>
                            <div class="dis-signal__chart">
                                <span class="dis-signal__chart-label">@sig.ChartLine1</span>
                                <span class="dis-signal__chart-label">@sig.ChartLine2</span>
                            </div>
                        </div>
                    }
                    <div class="dis-signals-col__footer">
                        <span>RISK LEVEL</span>
                        <div class="dis-risk-badges">
                            @foreach (var b in State.RiskBadges)
                            {
                                <span class="dis-badge dis-badge--risk">@b</span>
                            }
                        </div>
                    </div>
                </div>
                <div class="dis-signals-col">
                    <div class="dis-signals-col__header">ENTRY SIGNALS</div>
                    @foreach (var sig in State.EntrySignals)
                    {
                        <div class="dis-signal-row">
                            <span class="dis-signal__asset">@sig.Asset</span>
                            <div class="dis-signal__chart">
                                <span class="dis-signal__chart-label">@sig.ChartLine1</span>
                                <span class="dis-signal__chart-label">@sig.ChartLine2</span>
                            </div>
                            <span class="dis-badge dis-badge--xs dis-badge--dim">↓</span>
                        </div>
                    }
                    <div class="dis-signals-col__footer">
                        <span>RISK</span>
                        <div class="dis-risk-badges">
                            <span class="dis-badge dis-badge--risk">@State.EntryRisk</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- PANEL: Rank Diagnostics (stats) -->
        <div class="dis-panel">
            <div class="dis-panel__header">RANK DIAGNOSTICS</div>
            <div class="dis-panel__body">
                <div class="dis-stat-row"><span class="dis-stat__label">TOTAL LOGS:</span><span class="dis-stat__value">@State.TotalLogs</span></div>
                <div class="dis-stat-row"><span class="dis-stat__label">STATE CHANGES:</span><span class="dis-stat__value">@State.StateChanges</span></div>
                <div class="dis-stat-row"><span class="dis-stat__label">OUTPUT CHANGES:</span><span class="dis-stat__value">@State.OutputChanges</span></div>
                <div class="dis-stat-row"><span class="dis-stat__label">DECISION LOGS:</span><span class="dis-stat__value">@State.DecisionLogs</span></div>
                <div class="dis-stat-row"><span class="dis-stat__label">ACTION EVENTS:</span><span class="dis-stat__value">@State.ActionEvents</span></div>
            </div>
        </div>

        <!-- PANEL: Logging Summary (bottom right) -->
        <div class="dis-panel">
            <div class="dis-panel__header">LOGGING SUMMARY</div>
            <div class="dis-panel__body">
                <div class="dis-kv-row">
                    <span class="dis-kv__label">POSITION SIZE:</span>
                    <span class="dis-badge dis-badge--cyan dis-badge--arrow-up">@State.PositionSizeLabel</span>
                </div>
                <div class="dis-kv-row">
                    <span class="dis-kv__label">ENTERED SIZE:</span>
                    <span class="dis-kv__value">@State.EnteredSize LOTS</span>
                </div>
                <div class="dis-stat-row"><span class="dis-stat__label">TOTAL LOGS</span><span class="dis-stat__value">@State.TotalLogs</span></div>
                <div class="dis-stat-row"><span class="dis-stat__label">ACTIVE CYCLE:</span><span class="dis-stat__value dis-badge dis-badge--orange">@State.ActiveCycleLabel</span></div>
                <div class="dis-stat-row"><span class="dis-stat__label">LAST LOGGED:</span><span class="dis-stat__value dis-badge dis-badge--orange">@State.LastLogged</span></div>
                <div class="dis-kv-row">
                    <span class="dis-kv__label">STOP LOSS:</span>
                    <span class="dis-kv__value">@State.StopLossDisplay</span>
                    <span class="dis-badge dis-badge--green dis-badge--xs">↑</span>
                </div>
                <div class="dis-kv-row">
                    <span class="dis-kv__label">LAST ERROR:</span>
                    <span class="dis-badge dis-badge--dim">@State.LastError</span>
                </div>
            </div>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════
         FOOTER — LOGGING INSIGHT
    ═══════════════════════════════════════════════════════════ -->
    <footer class="dis-footer">
        <span class="dis-footer__label">LOGGING INSIGHT:</span>
        <span class="dis-footer__item">TOTAL LOGS: <strong>@State.TotalLogs</strong></span>
        <span class="dis-footer__sep">|</span>
        <span class="dis-footer__item">STATE CHANGES: <strong>@State.StateChanges</strong></span>
        <span class="dis-footer__sep">|</span>
        <span class="dis-footer__item">OUTPUT CHANGES: <strong>@State.OutputChanges</strong></span>
        <span class="dis-footer__sep">|</span>
        <span class="dis-footer__item">DECISION LOGS: <strong>@State.DecisionLogs</strong></span>
        <span class="dis-footer__sep">|</span>
        <span class="dis-footer__item">ACTION EVENTS: <strong>@State.ActionEvents</strong></span>
    </footer>
</div>

@code {
    private DashboardState State => StateService.Current;
    private DateTime _now = DateTime.UtcNow;
    private System.Threading.Timer? _clockTimer;

    protected override void OnInitialized()
    {
        _clockTimer = new System.Threading.Timer(_ =>
        {
            _now = DateTime.UtcNow;
            InvokeAsync(StateHasChanged);
        }, null, 0, 1000);

        StateService.OnStateChanged += HandleStateChanged;
    }

    private void HandleStateChanged() => InvokeAsync(StateHasChanged);

    private static string GetLogTypeClass(string type) => type switch
    {
        "STATE CHANGE:" => "dis-log__type--state",
        "OUTPUT CHANGE:" => "dis-log__type--output",
        "ENTRY SIGNAL" => "dis-log__type--entry",
        "EXECUTION" => "dis-log__type--exec",
        "EXIT" => "dis-log__type--exit",
        _ => ""
    };

    public void Dispose()
    {
        _clockTimer?.Dispose();
        StateService.OnStateChanged -= HandleStateChanged;
    }
}

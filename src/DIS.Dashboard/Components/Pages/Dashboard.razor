@page "/"
@using DIS.Dashboard.Models
@using DIS.Dashboard.Components.Panels
@implements IDisposable
@inject IDashboardStateService StateService

<PageTitle>DIS — Decision Intelligence System</PageTitle>

<div class="dis-dashboard">

    <!-- ═══════════ HEADER ═══════════ -->
    <RadzenRow class="dis-header" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center" Gap="0">
        <RadzenColumn>
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="12px">
                <RadzenText TextStyle="TextStyle.H6" class="dis-brand">DECISION INTELLIGENCE SYSTEM</RadzenText>
                <RadzenBadge Text="DASHBOARD" BadgeStyle="BadgeStyle.Info" class="dis-header-badge" />
            </RadzenStack>
        </RadzenColumn>
        <RadzenColumn class="rz-text-align-end">
            <RadzenText TextStyle="TextStyle.Body2" class="dis-clock-time">@_now.ToString("HH:mm:ss")</RadzenText>
            <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-text-disabled-color);">@_now.ToString("yyyy-MM-dd")</RadzenText>
        </RadzenColumn>
    </RadzenRow>

    <!-- ═══════════ ROW 1 ═══════════ -->
    <div class="dis-grid dis-grid--top">
        <CurrentSystemState State="State" />
        <OutputDiagnostics  State="State" />
        <PortfolioOverview  State="State" />
    </div>

    <!-- ═══════════ ROW 2 ═══════════ -->
    <div class="dis-grid dis-grid--mid">
        <ActiveTrades    State="State" />
        <RankDiagnostics State="State" />
        <LoggingSummary  State="State" />
    </div>

    <!-- ═══════════ ROW 3 ═══════════ -->
    <div class="dis-grid dis-grid--bot">
        <EntryExitSignals     State="State" />
        <RankStats            State="State" />
        <LoggingFooterSummary State="State" />
    </div>

    <!-- ═══════════ FOOTER ═══════════ -->
    <RadzenRow class="dis-footer" AlignItems="AlignItems.Center" Gap="0">
        <RadzenColumn Size="12">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="12px" Wrap="FlexWrap.Wrap">
                <RadzenText TextStyle="TextStyle.Overline" Style="color:var(--rz-text-disabled-color); letter-spacing:1.5px;">LOGGING INSIGHT</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2">TOTAL LOGS: <strong style="color:var(--rz-text-color);">@State.TotalLogs</strong></RadzenText>
                <span class="dis-sep">|</span>
                <RadzenText TextStyle="TextStyle.Body2">STATE CHANGES: <strong style="color:var(--rz-text-color);">@State.StateChanges</strong></RadzenText>
                <span class="dis-sep">|</span>
                <RadzenText TextStyle="TextStyle.Body2">OUTPUT CHANGES: <strong style="color:var(--rz-text-color);">@State.OutputChanges</strong></RadzenText>
                <span class="dis-sep">|</span>
                <RadzenText TextStyle="TextStyle.Body2">DECISION LOGS: <strong style="color:var(--rz-text-color);">@State.DecisionLogs</strong></RadzenText>
                <span class="dis-sep">|</span>
                <RadzenText TextStyle="TextStyle.Body2">ACTION EVENTS: <strong style="color:var(--rz-text-color);">@State.ActionEvents</strong></RadzenText>
            </RadzenStack>
        </RadzenColumn>
    </RadzenRow>

</div>

@code {
    private DashboardState State => StateService.Current;
    private DateTime _now = DateTime.UtcNow;
    private System.Threading.Timer? _clockTimer;

    protected override void OnInitialized()
    {
        _clockTimer = new System.Threading.Timer(_ =>
        {
            _now = DateTime.UtcNow;
            InvokeAsync(StateHasChanged);
        }, null, 0, 1000);

        StateService.OnStateChanged += HandleStateChanged;
    }

    private void HandleStateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        _clockTimer?.Dispose();
        StateService.OnStateChanged -= HandleStateChanged;
    }
}

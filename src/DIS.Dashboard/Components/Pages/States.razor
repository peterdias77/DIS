@page "/states"
@using System.Text.Json
@using DIS.Core.Models
@using DIS.Dashboard.Services
@inject ILogReader LogReader
@inject DashboardHubClient HubClient
@implements IDisposable

<h1>State Monitor</h1>

<div class="dis-filter-bar">
    <label>Asset:</label>
    <select @bind="_selectedAsset">
        <option value="">All</option>
        @foreach (var asset in _latestStates.Keys.OrderBy(k => k))
        {
            <option value="@asset">@asset</option>
        }
    </select>
</div>

@foreach (var kvp in _latestStates
    .Where(k => string.IsNullOrEmpty(_selectedAsset) || k.Key == _selectedAsset)
    .OrderBy(k => k.Key))
{
    <div class="dis-asset-panel">
        <h3>@kvp.Key</h3>
        <div class="dis-state-grid">
            @foreach (var state in kvp.Value.OrderBy(s => s.Key))
            {
                <div class="dis-state-chip">
                    <label>@state.Key</label>
                    <span>@state.Value</span>
                </div>
            }
        </div>
    </div>
}

@code {
    // asset → (stateName → currentValue)
    private Dictionary<string, Dictionary<string, string>> _latestStates = new();
    private string _selectedAsset = "";

    protected override async Task OnInitializedAsync()
    {
        var history = await LogReader.GetByEventTypeAsync("state_change", 1000);

        foreach (var entry in history.OrderBy(e => e.Id))
            ApplyStateChange(entry);

        HubClient.OnLogEntry += OnLiveEntry;
    }

    private void OnLiveEntry(DISLogEntry entry)
    {
        if (entry.EventType != "state_change") return;

        InvokeAsync(() =>
        {
            ApplyStateChange(entry);
            StateHasChanged();
        });
    }

    private void ApplyStateChange(DISLogEntry entry)
    {
        try
        {
            var doc = JsonDocument.Parse(entry.Payload);
            var stateName = doc.RootElement.GetProperty("state").GetString() ?? "";
            var toValue   = doc.RootElement.GetProperty("to").GetString()    ?? "";

            if (!_latestStates.TryGetValue(entry.Asset, out var states))
            {
                states = new Dictionary<string, string>();
                _latestStates[entry.Asset] = states;
            }

            states[stateName] = toValue;
        }
        catch { /* malformed payload — skip */ }
    }

    public void Dispose() => HubClient.OnLogEntry -= OnLiveEntry;
}

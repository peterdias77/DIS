@page "/trades"
@using System.Text.Json
@using DIS.Core.Models
@using DIS.Dashboard.Services
@inject ILogReader LogReader
@inject DashboardHubClient HubClient
@implements IDisposable

<h1>Active Trades</h1>

@if (!_trades.Any())
{
    <p class="dis-empty">No active trades recorded yet.</p>
}
else
{
    <table class="dis-table">
        <thead>
            <tr>
                <th>Asset</th>
                <th>Cycle</th>
                <th>Signal</th>
                <th>Entry Price</th>
                <th>Stop Loss</th>
                <th>Take Profit</th>
                <th>Size</th>
                <th>Risk %</th>
                <th>Position</th>
                <th>Time</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var t in _trades.Values.OrderBy(t => t.Asset))
            {
                <tr>
                    <td><strong>@t.Asset</strong></td>
                    <td>@t.CycleId</td>
                    <td class="@t.Signal.ToLower()">@t.Signal</td>
                    <td>@t.EntryPrice</td>
                    <td>@t.StopLoss</td>
                    <td>@t.TakeProfit</td>
                    <td>@t.PositionSize</td>
                    <td>@t.RiskPercent%</td>
                    <td>@t.PositionState</td>
                    <td>@t.Timestamp.ToString("HH:mm:ss")</td>
                </tr>
            }
        </tbody>
    </table>
}

<h2>Recent Trade Events</h2>
<table class="dis-table">
    <thead>
        <tr>
            <th>Time</th>
            <th>Asset</th>
            <th>Event</th>
            <th>Detail</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var e in _recentTradeEvents.Take(30))
        {
            <tr>
                <td>@e.Timestamp.ToString("HH:mm:ss")</td>
                <td>@e.Asset</td>
                <td>@e.EventType</td>
                <td class="dis-payload">@e.Payload</td>
            </tr>
        }
    </tbody>
</table>

@code {
    private Dictionary<string, TradeRow> _trades = new();
    private List<DISLogEntry> _recentTradeEvents = new();

    protected override async Task OnInitializedAsync()
    {
        foreach (var type in new[] { "entry", "risk", "exit", "execution" })
        {
            var entries = await LogReader.GetByEventTypeAsync(type, 100);
            foreach (var e in entries.OrderBy(x => x.Id))
                ProcessEntry(e);
        }

        HubClient.OnLogEntry += OnLiveEntry;
    }

    private void OnLiveEntry(DISLogEntry entry)
    {
        if (entry.EventType is not ("entry" or "risk" or "exit" or "execution")) return;

        InvokeAsync(() =>
        {
            ProcessEntry(entry);
            StateHasChanged();
        });
    }

    private void ProcessEntry(DISLogEntry entry)
    {
        _recentTradeEvents.Insert(0, entry);
        if (_recentTradeEvents.Count > 100) _recentTradeEvents.RemoveAt(100);

        try
        {
            var doc = JsonDocument.Parse(entry.Payload);

            if (entry.EventType == "entry")
            {
                _trades[entry.Asset] = new TradeRow
                {
                    Asset         = entry.Asset,
                    CycleId       = entry.CycleId,
                    Signal        = doc.RootElement.GetProperty("signal").GetString() ?? "",
                    EntryPrice    = doc.RootElement.GetProperty("price").GetDecimal(),
                    Timestamp     = entry.Timestamp,
                    PositionState = "FULL"
                };
            }
            else if (entry.EventType == "risk" && _trades.TryGetValue(entry.Asset, out var t))
            {
                t.StopLoss     = doc.RootElement.GetProperty("stop_loss").GetDecimal();
                t.PositionSize = doc.RootElement.GetProperty("position_size").GetDecimal();
                t.RiskPercent  = doc.RootElement.GetProperty("risk_percent").GetDecimal() * 100;
                // TODO: wire take_profit when logged
            }
            else if (entry.EventType == "exit" && _trades.TryGetValue(entry.Asset, out var t2))
            {
                var state = doc.RootElement.GetProperty("position_state").GetString() ?? "";
                if (state == "Closed")
                    _trades.Remove(entry.Asset);
                else
                    t2.PositionState = state;
            }
        }
        catch { /* malformed payload — skip */ }
    }

    public void Dispose() => HubClient.OnLogEntry -= OnLiveEntry;

    private sealed class TradeRow
    {
        public string  Asset         { get; set; } = "";
        public int     CycleId       { get; set; }
        public string  Signal        { get; set; } = "";
        public decimal EntryPrice    { get; set; }
        public decimal StopLoss      { get; set; }
        public decimal TakeProfit    { get; set; }
        public decimal PositionSize  { get; set; }
        public decimal RiskPercent   { get; set; }
        public string  PositionState { get; set; } = "";
        public DateTime Timestamp    { get; set; }
    }
}

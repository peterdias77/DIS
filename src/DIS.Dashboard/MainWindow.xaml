<Window
    x:Class="DIS.Dashboard.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
    Title="DIS — Decision Intelligence System Dashboard"
    Height="1080"
    Width="1920"
    WindowState="Maximized"
    Background="#0D0D0D">

    <Grid>
        <!--
            WebView2 control renders the Blazor Server UI.
            Source points to the in-process Blazor host on localhost:5100.
            The dashboard is read-only — no execution commands are issued from here.
        -->
        <wv2:WebView2
            x:Name="DashboardWebView"
            Source="http://localhost:5100" />
    </Grid>

</Window>
